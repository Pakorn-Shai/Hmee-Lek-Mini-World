{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": [],
    "typeRoots": [
      "./@types"
    ]
  },
  "include": [
    "src/**/*.ts",
    "@types/**/*.d.ts"
  ]
}
